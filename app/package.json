{
  "name": "app",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "psql \"$DATABASE_URL\" -f db/seed.sql",
    "db:check:rls": "psql \"$DATABASE_URL\" -f db/rls_check.sql",
    "build": "bun build src/index.ts --target bun --outdir /private/tmp/garage-api-build",
    "typecheck": "bunx tsc --noEmit --skipLibCheck",
    "lint": "bun run typecheck",
    "ci": "bun run typecheck && bun test && bun run build",
    "test": "bun test",
    "test:integration": "bun test src/integration"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.19",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  }
}
